{
  // 🐍 Python / Pipenv
  "python.terminal.activateEnvironment": true,
  "python.defaultInterpreterPath": "C:\\Users\\Usuario\\Desktop\\fhir-gateway-viewer-lite\\apps\\api\\.venv\\Scripts\\python.exe",
  // 🔎 Type checking (Pylance)
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.extraPaths": [
    "apps/api/src"
  ],
  // 🧪 Pytest
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "python.testing.cwd": "${workspaceFolder}/apps/api",
  "python.testing.pytestArgs": [
    "tests"
  ],
  // 🧹 Ruff
  "ruff.enable": true,
  "ruff.lint.enable": true,
  "ruff.format.enable": false,
  // 🎨 Formatting
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter"
  },
  "editor.formatOnSave": true,
  // 🧠 Editor
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "editor.tabSize": 4,
  "editor.detectIndentation": false,
  // 📦 Python environments extension
  "python-envs.pythonProjects": [
    {
      "path": "apps/api",
      "envManager": "ms-python.python:pipenv",
      "packageManager": "ms-python.python:pip"
    }
  ]
}
