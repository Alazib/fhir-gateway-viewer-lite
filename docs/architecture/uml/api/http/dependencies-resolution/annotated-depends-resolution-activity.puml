@startuml
title FastAPI dependency graph and request resolution: How FastAPI resolves Annotated[X, Depends(provider)]

skinparam shadowing false
skinparam noteMaxWidth 320

start


partition "A. Route registration\nExecuted when the route is added" {

    :FastAPI registers the endpoint;

    note right
    Future example:

    GET /patients/{patient_id}/summary
    end note


    :Inspect endpoint function signature;

    note right
    Conceptual endpoint parameters:

    principal:
        Annotated[
            CurrentPrincipal,
            Depends(get_current_principal)
        ]

    use_case:
        Annotated[
            GetPatientSummaryUseCase,
            Depends(get_patient_summary_use_case)
        ]
    end note


    :Detect every Depends(provider);

    note right
    Detected root dependencies:

    get_current_principal

    get_patient_summary_use_case
    end note


    :Recursively inspect each provider signature;

    note right
    Security branch:

    get_current_principal
        -> bearer_scheme
        -> get_jwt_token_verifier

    Persistence/application branch:

    get_patient_summary_use_case
        -> get_patient_reader
            -> get_database_session
        -> get_condition_reader
            -> get_database_session
        -> get_encounter_reader
            -> get_database_session
        -> get_observation_reader
            -> get_database_session
    end note


    :Build dependency graph for the route;

    :Store graph with the registered route;

    note right
    Important:

    No Session is created.
    No adapter is created.
    No use case is created.
    No JWT is verified.

    FastAPI is only building
    the execution plan.
    end note
}


partition "B. HTTP request\nExecuted once per request" {

    :Client sends HTTP request;

    :FastAPI matches the registered route;

    :Load the route dependency graph;

    :Create an empty dependency cache
    for this request;
}


partition "C. Resolve security branch" {

    :Resolve deepest security subdependencies;

    :Execute HTTPBearer;

    note right
    Result:

    HTTPAuthorizationCredentials
    end note


    :Execute get_jwt_token_verifier(request);

    note right
    Reads:

    request.app.state.jwt_token_verifier

    Result:

    JwtTokenVerifier V1
    end note


    :Execute get_current_principal(
        credentials,
        verifier=V1
    );

    :Verify raw JWT;

    :Create VerifiedJwtClaims;

    :Create CurrentPrincipal P1;

    :Store CurrentPrincipal P1
    as resolved endpoint value;
}


partition "D. Resolve use-case branch" {

    :FastAPI needs
    GetPatientSummaryUseCase;

    :Inspect its four unresolved reader dependencies;


    :Resolve get_database_session(request);

    note right
    FastAPI dependency node:

    get_database_session

    Inside that function,
    normal Python code calls:

    get_session_factory(request)

    get_session_factory is not currently
    another Depends() node.
    end note


    :get_database_session calls
    get_session_factory(request);

    :Read request.app.state.session_factory;

    :Create SQLAlchemy Session S1;

    :yield Session S1;

    :Store Session S1 in request cache;

    note right
    get_database_session is suspended
    at the yield statement.

    Its cleanup will run later.
    end note


    :Execute get_patient_reader(session=S1);

    :Create PatientReader PR1;


    :Condition reader also requests
    get_database_session;

    if (get_database_session already cached?) then (yes)

        :Reuse Session S1;

    else (no)

        :Execute get_database_session again;

    endif

    :Execute get_condition_reader(session=S1);

    :Create ConditionReader CR1;


    :Encounter reader requests
    get_database_session;

    :Reuse cached Session S1;

    :Execute get_encounter_reader(session=S1);

    :Create EncounterReader ER1;


    :Observation reader requests
    get_database_session;

    :Reuse cached Session S1;

    :Execute get_observation_reader(session=S1);

    :Create ObservationReader OR1;


    :Execute get_patient_summary_use_case(
        patient_reader=PR1,
        condition_reader=CR1,
        encounter_reader=ER1,
        observation_reader=OR1
    );

    :Create GetPatientSummaryUseCase UC1;

    :Store UC1 as resolved endpoint value;
}


partition "E. Execute endpoint" {

    :All endpoint parameters are ready;

    note right
    FastAPI can now make the conceptual call:

    endpoint(
        patient_id="pat-001",
        principal=P1,
        use_case=UC1
    )
    end note


    :Execute endpoint;

    :Endpoint invokes UC1.execute(patient_id);

    :Use case uses the four readers;

    :Readers use shared Session S1;

    :Build PatientSummary;

    :Return endpoint result;

    :Serialize HTTP response;
}


partition "F. Cleanup yield dependencies" {

    :Resume get_database_session()
    after yield;

    :Exit SQLAlchemy Session context manager;

    :Close Session S1;

    :Finish request;
}


stop

@enduml
